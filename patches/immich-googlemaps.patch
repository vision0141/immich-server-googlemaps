   const toggleAssetPath = () => (showAssetPath = !showAssetPath);
 
+  const getDmsComponent = (value: number, positive: string, negative: string) => {
+    const absolute = Math.abs(value);
+    const degrees = Math.floor(absolute);
+    const minutesFloat = (absolute - degrees) * 60;
+    const minutes = Math.floor(minutesFloat);
+    const seconds = ((minutesFloat - minutes) * 60).toFixed(1);
+    const direction = value >= 0 ? positive : negative;
+
+    return `${degrees}°${minutes}'${seconds}"${direction}`;
+  };
+
+  const getGoogleMapsHref = (lat: number, lon: number) => {
+    const latDms = getDmsComponent(lat, 'N', 'S');
+    const lonDms = getDmsComponent(lon, 'E', 'W');
+    const place = encodeURIComponent(`${latDms} ${lonDms}`);
+
+    return `https://www.google.com/maps/place/${place}/@${lat},${lon},450m`;
+  };
